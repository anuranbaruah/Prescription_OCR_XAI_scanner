# Copy to ".env" and adjust as needed. All vars are optional.
RXAI_DEVICE=auto                 # auto | cpu | cuda
RXAI_PRIMARY_OCR=trocr           # trocr | easyocr | tesseract
RXAI_TROCR_MODEL=microsoft/trocr-base-handwritten
RXAI_NER_MODEL=d4data/biomedical-ner-all
RXAI_FUZZY_THRESHOLD=85
RXAI_TOP_K_GENERICS=3
RXAI_ENABLE_XAI=true
# Path to your fine-tuned YOLOv8 text-region weights (optional)
# RXAI_YOLO_WEIGHTS=models/yolov8n_rx.pt
